# ============================================================
# Alchemy SI — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# ---- REQUIRED ----
ANTHROPIC_API_KEY=                    # Get from console.anthropic.com

# ---- LEAD SCRAPING ----
APIFY_API_TOKEN=                      # Get from apify.com — for Google Maps + web scraping

# ---- COLD EMAIL ----
INSTANTLY_API_KEY=                    # Get from instantly.ai — for campaign management

# ---- PROPOSALS ----
PANDADOC_API_KEY=                     # Get from pandadoc.com — for proposal generation

# ---- IMAGE GENERATION ----
FLUX_API_KEY=                         # Get from fal.ai or Replicate — for AI image gen
IDEOGRAM_API_KEY=                     # Get from ideogram.ai — alternative image gen

# ---- GOOGLE (for Sheets, Gmail) ----
# Download credentials.json from Google Cloud Console (Desktop OAuth app)
# Place it in the root directory — DO NOT add it to git
GOOGLE_CREDENTIALS_PATH=credentials.json

# ---- VECTOR SEARCH (for RAG / document search) ----
OPENAI_API_KEY=                       # Get from platform.openai.com — for embeddings
PINECONE_API_KEY=                     # Get from pinecone.io — for vector storage

# ---- CLOUD INFRASTRUCTURE ----
MODAL_TOKEN_ID=                       # Set up via: modal token new
MODAL_TOKEN_SECRET=

# ---- SUPABASE (optional — for lead storage) ----
SUPABASE_URL=
SUPABASE_KEY=

# ---- SLACK (optional — for webhook notifications) ----
SLACK_WEBHOOK_URL=

# ---- EMAIL CONFIG ----
FROM_EMAIL=connect@alchemysi.uk       # Update to your sending email
FROM_NAME=Alchemy System Integration
